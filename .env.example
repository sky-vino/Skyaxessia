# =============================================================================
# Axessia — Local Development Environment
# =============================================================================
# Copy this file to backend/.env and fill in real values. NEVER commit
# backend/.env — it is git-ignored.
#
# In Azure, none of these live in a file. They are set under:
#   axessia-app → Configuration → Environment variables
# =============================================================================

# --- Database -----------------------------------------------------------------
# Local dev writes to backend/data/. Azure writes to /home/data (persistent).
DATABASE_URL=sqlite://data/accessibility.sqlite

# --- Default seeded admin (auto-created on first boot) ------------------------
DEFAULT_ADMIN_EMAIL=admin@axessia.local
DEFAULT_ADMIN_PASSWORD=Admin@123

# --- JWT secrets (MUST be strong random strings in production) ----------------
JWT_SECRET=change-me-to-a-64-character-random-string
JWT_REFRESH_SECRET=change-me-to-a-DIFFERENT-64-character-random-string

# --- Azure OpenAI (REQUIRED for AI-assisted explanations) ---------------------
# Endpoint format: https://<your-resource-name>.openai.azure.com
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_KEY=your-azure-openai-key-here
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-10-21

# --- URLs (local dev) ---------------------------------------------------------
FRONTEND_URL=http://localhost:3000
VITE_API_URL=http://localhost:4000

# --- Server -------------------------------------------------------------------
PORT=4000
NODE_ENV=development

# --- Scan queue ---------------------------------------------------------------
SCAN_QUEUE_DRIVER=memory
SCAN_QUEUE_CONCURRENCY=2

# --- Playwright (local: leave unset to use ~/.cache/ms-playwright) ------------
# PLAYWRIGHT_BROWSERS_PATH=

# --- CORS allow-list (comma-separated, or leave unset for '*') ----------------
# AXESSIA_ALLOWED_ORIGINS=https://axessia-app.azurewebsites.net
